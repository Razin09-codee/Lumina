FROM php:8.2-apache

# Install cURL extension required for Gemini API requests
RUN apt-get update && apt-get install -y libcurl4-opensmith-dev libcurl4-openssl-dev \
    && docker-php-ext-install curl

# Copy your search engine script into the Apache web directory
COPY search-engine.php /var/www/html/search-engine.php

# Expose port 80 for Render
EXPOSE 80
