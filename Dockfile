FROM php:8.2-apache

# Install cURL extension required for Gemini API requests
RUN apt-get update && apt-get install -y libcurl4-openssl-dev \
    && docker-php-ext-install curl

# Enable Apache rewrite engine modules
RUN a2enmod rewrite

# Copy your script into the default Apache directory
COPY ai-handler.php /var/www/html/ai-handler.php

# Tell Apache to listen to port 80 internally
EXPOSE 80